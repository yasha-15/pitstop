# ─── Email Credentials (Gmail SMTP) ───────────────────────────────────────────
# The Gmail address that will SEND the OTP / reset emails
EMAIL_USER=your_gmail@gmail.com

# Gmail App Password (NOT your regular password)
# How to get one:
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Select "Mail" → "Other" → name it "track-app"
#   4. Copy the 16-character password (spaces don't matter) and paste below
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ─── JWT Secret ───────────────────────────────────────────────────────────────
# Any long random string — used to sign login tokens
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_string

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
BASE_URL=http://localhost:3000
